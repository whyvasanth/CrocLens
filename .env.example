# CrocLens environment template.
# Copy to .env for local development. Never commit real .env files or secrets.

# Shared application behavior
APP_ENV=local
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=300
DEMO_MODE_ENABLED=true

# Backend API
DATABASE_URL=postgresql+psycopg://croclens:croclens@localhost:5432/croclens
AUTH_MODE=local
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# AWS/Cognito placeholders. Do not create AWS resources until the deployment ADR and cost review are complete.
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=

# Market data. yfinance is unofficial/prototype data and may be delayed or incomplete.
MARKET_DATA_PROVIDER=yfinance
MARKET_DATA_CACHE_SECONDS=300

# Frontend public settings. Values starting with NEXT_PUBLIC_ are visible in browser bundles.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
NEXT_PUBLIC_DEMO_MODE_ENABLED=true
