{
  "name": "croclens",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @croclens/web",
    "build:web": "npm run build --workspace @croclens/web",
    "typecheck:web": "npm run typecheck --workspace @croclens/web",
    "test:web": "npm run test --workspace @croclens/web",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
